# Baseline experiment defaults used by wrapper scripts.
# Override these via environment variables in SLURM scripts or command line.

export RUN_NAME="${RUN_NAME:-baseline_full_ft}"
export WANDB_PROJECT="${WANDB_PROJECT:-dima-course}"

# Training controls
export TRAINING_ITERS="${TRAINING_ITERS:-20000}"
export EVAL_INTERVAL="${EVAL_INTERVAL:-2000}"
export SAVE_INTERVAL="${SAVE_INTERVAL:-2000}"

# Single-GPU baseline defaults
export BATCH_SIZE="${BATCH_SIZE:-32}"
export BATCH_SIZE_PER_GPU="${BATCH_SIZE_PER_GPU:-32}"

# Sampling controls for periodic eval
export GEN_STEPS="${GEN_STEPS:-500}"
export GEN_SAMPLES="${GEN_SAMPLES:-256}"
